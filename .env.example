─────
# ExamVault — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Get these from: Azure Portal → Your OpenAI Resource → Keys and Endpoint
VITE_AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com
VITE_AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4
VITE_AZURE_OPENAI_API_VERSION=2024-02-01

# ── Authentication ─────────────────────────────────────────────────────────────
# Change this to a long random string in production (min 32 chars)
VITE_JWT_SECRET=examvault-change-this-secret-in-production-min-32-chars

# ── EmailJS ───────────────────────────────────────────────────────────────────
# Get these from: https://www.emailjs.com → Account → API Keys
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id

# EmailJS Template IDs (create these in your EmailJS dashboard)
VITE_EMAILJS_TEMPLATE_EXAM_INVITE=template_exam_invite
VITE_EMAILJS_TEMPLATE_RESULT_PUBLISH=template_result_publish
VITE_EMAILJS_TEMPLATE_VIOLATION_ALERT=template_violation_alert
VITE_EMAILJS_TEMPLATE_WELCOME=template_welcome
VITE_EMAILJS_TEMPLATE_RESET_PASSWORD=template_reset_password

# ── SharePoint (optional — for production data layer) ─────────────────────────
# Set HAS_IN_MEMORY_TABLES=false and configure SharePoint to use real data
VITE_SHAREPOINT_SITE_URL=https://YOUR_TENANT.sharepoint.com/sites/ExamVault
VITE_SHAREPOINT_CLIENT_ID=your_sharepoint_app_client_id

# ── App Config ────────────────────────────────────────────────────────────────
VITE_APP_NAME=ExamVault
VITE_APP_URL=https://apps.powerapps.com/play/e/6ecfa998-d68e-e5c3-9189-08c73489e1d3/app/2495893f-f9f6-4973-a240-1696bac6ba48?tenantId=7359f896-71e2-4dae-b8a3-15cdf97f2f10&sourcehint=3&hint=0feaaea2-c164-4c93-b60a-c93bffda6ff9&sourcetime=1778345229027&source=vibe
